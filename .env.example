# Copia este archivo como .env y rellena tus claves
OPENAI_API_KEY=sk-proj-...

# Token de acceso local (opcional).
# Si se define, todas las llamadas a /api/* requieren el header: X-Token: <valor>
# Útil si expones el servidor en una red local y no quieres que otros lo usen.
# Dejar vacío o comentado para acceso libre en localhost.
# LOCAL_TOKEN=mi-token-secreto
